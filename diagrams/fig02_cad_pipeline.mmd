    %% Architecture branch
    AG["Architecture graph"] --> CF["Component fragility<br/>score"]

    %% Event-log branch
    EL["EHR event logs"] --> PM["Process mining:<br/>variants and frequencies"]
    PM --> PC["Pathway frequency<br/>and criticality"]

    %% Trace branch
    DT["Distributed traces"] --> TM["Trace-to-service<br/>mapping"]
    TM --> SE["Service exposure<br/>by pathway"]

    %% CAD aggregation
    CF --> CAD["CAD scoring"]
    PC --> CAD
    SE --> CAD

    %% Ranking and outputs
    CAD --> RANK["Component ranking"]
    RANK --> MAINT["Maintenance prioritization"]
    RANK --> METRICS["Ranking metrics:<br/>P@10 / R@10 / MAP / CI"]

