%% Figure A.2 - Runtime observability, synchronization, CAD evidence, backup and test flows
flowchart LR

  subgraph RUNTIME[Runtime sources]
    direction TB
    NGINX["Nginx"]
    HAP["HAProxy"]
    CORE["BioArc Core Engine"]
    INT["Internal integration layer"]
    MDB[("MariaDB cluster")]
    REDIS[("Redis queue and cache")]
    CH[("ClickHouse analytics")]
  end

  subgraph OBS[Observability and monitoring]
    direction TB
    NLOG["Nginx access logs"]
    HLOG["HAProxy routing and rate-limit logs"]
    ALOG["Application logs"]
    ILOG["API and integration logs"]
    CID["Correlation IDs"]
    MAP["Trace-to-service mapping"]
    COLLECT["Log collector"]
    METRIC["Metrics store"]
    DASH["Monitoring dashboard"]
    ALERT["Operational alert manager"]
  end

  subgraph SYNC[Background synchronization]
    direction TB
    CRON["Cron scheduler\nMinutely, hourly and nightly"]
    HOSP["Hospital data sync"]
    TICKET["Ticket sync"]
    INS["Insurance, drug and coding sync"]
    WARN["Warning and announcement sync"]
  end

  subgraph EVIDENCE[CAD evidence and evaluation inputs]
    direction TB
    EVENT["Event-log extracts"]
    TRACE["Runtime traces"]
    EXPOSURE["Service exposure by pathway"]
    CADE["CAD evidence layer"]
  end

  subgraph SUPPORT[Backup and test support]
    direction TB
    RESTIC["restic backup jobs"]
    PROD["Production environment\nBare-metal servers"]
    TEST["Test environment\nIsolated test deployment"]
  end

  NGINX -->|"access logs"| NLOG
  HAP -->|"routing logs"| HLOG
  CORE -->|"application logs"| ALOG
  INT -->|"API logs"| ILOG
  NLOG --> COLLECT
  HLOG --> COLLECT
  ALOG --> COLLECT
  ILOG --> COLLECT
  CORE -->|"correlation IDs"| CID
  INT -->|"correlation IDs"| CID
  CID --> MAP
  COLLECT --> METRIC
  METRIC --> DASH
  METRIC --> ALERT

  CRON -->|"queued jobs"| HOSP
  CRON -->|"queued jobs"| TICKET
  CRON -->|"queued jobs"| INS
  CRON -->|"queued jobs"| WARN
  HOSP -->|"updates"| INT
  TICKET -->|"updates"| CORE
  INS -->|"reference data"| INT
  WARN -->|"updates"| CORE

  MDB -->|"event logs"| EVENT
  MAP -->|"runtime traces"| TRACE
  TRACE -->|"trace links"| EXPOSURE
  CH -->|"usage summaries"| EXPOSURE
  EVENT --> CADE
  EXPOSURE --> CADE

  MDB -->|"hosts"| PROD
  REDIS -->|"hosts"| PROD
  CH -->|"hosts"| PROD
  PROD -->|"snapshots"| RESTIC
  RESTIC -->|"metadata"| CADE
  PROD -->|"regression runs"| TEST
  TEST -->|"test traces"| CADE

  classDef runtime fill:#eefaf4,stroke:#3b8161,stroke-width:1px,color:#173d2c;
  classDef obs fill:#eef7ff,stroke:#3d78a8,stroke-width:1px,color:#16334a;
  classDef sync fill:#fff7e8,stroke:#a87324,stroke-width:1px,color:#4d3510;
  classDef evidence fill:#f7f1ff,stroke:#7656a8,stroke-width:1px,color:#2f1c4a;
  classDef support fill:#fff1f2,stroke:#a45159,stroke-width:1px,color:#4c1e22;

  class NGINX,HAP,CORE,INT,MDB,REDIS,CH runtime;
  class NLOG,HLOG,ALOG,ILOG,CID,MAP,COLLECT,METRIC,DASH,ALERT obs;
  class CRON,HOSP,TICKET,INS,WARN sync;
  class EVENT,TRACE,EXPOSURE,CADE evidence;
  class RESTIC,PROD,TEST support;
